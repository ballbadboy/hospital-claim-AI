# AI Provider: "anthropic" (cloud) หรือ "ollama" (local, ไม่ต้อง API key)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Ollama (ใช้เมื่อ AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/hospital_claim_ai
LINE_CHANNEL_TOKEN=your_line_token
LINE_CHANNEL_SECRET=your_line_secret
FDH_API_URL=https://fdh.moph.go.th/api
FDH_API_KEY=your_fdh_key
APP_ENV=development
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-this-to-at-least-32-chars-long-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_HOURS=8
